# --- General ---
NODE_ENV=development
DRY_RUN=true
LOG_LEVEL=info

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abitare_marketing
DB_USER=abitare
DB_PASSWORD=abitare_dev_password
DATABASE_URL=postgres://abitare:abitare_dev_password@localhost:5432/abitare_marketing

# --- Meta Marketing API ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# Formato: store_key:ad_account_id, separado por comas (una cuenta por tienda)
META_AD_ACCOUNTS=bcn_kids:act_XXXXXXXXX,lux_kids:act_XXXXXXXXX,lux_living:act_XXXXXXXXX
META_API_VERSION=v19.0

# --- Google Ads API ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Formato: store_key:customer_id, separado por comas (una cuenta por tienda)
GOOGLE_ADS_CUSTOMER_ACCOUNTS=bcn_kids:1234567890,lux_kids:1234567891,lux_living:1234567892

# --- Odoo ---
# El acceso actual a Odoo es solo storefront (Shopinvader), no backend/XML-RPC,
# asi que ODOO_LIVE_SYNC_ENABLED queda en false y los pedidos se cargan a mano
# via `npm run import:sales` (ver connectors/salesCsvImport.js). Cambiar a
# true solo si se consigue acceso real de backend a Odoo.
ODOO_LIVE_SYNC_ENABLED=false
ODOO_URL=https://abitare.odoo.com
ODOO_DB=abitare-prod
ODOO_USERNAME=
ODOO_API_KEY=
# Un unico despliegue de Odoo sirve las 3 tiendas; se distinguen por website_id.
# Formato: website_id:store_key, separado por comas.
ODOO_WEBSITE_STORE_MAP=1:bcn_kids,2:lux_kids,3:lux_living

# --- Scheduler: sincroniza Meta/Google Ads automaticamente cada dia ---
SYNC_CRON_SCHEDULE=0 6 * * *
